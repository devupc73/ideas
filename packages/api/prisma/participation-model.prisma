model Participation {
  id        String   @id @default(uuid())

  userId    String
  matchId   String

  status    String   // confirmed | waiting_list | removed
  paid      Boolean  @default(false)

  team      String?  // A | B
  position  Int?

  paymentId String?

  joinedAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([userId])
}
